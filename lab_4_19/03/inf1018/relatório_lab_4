Questão 3 - Função xbyte

int xbyte (packed_t word, int bytenum) {
  if (bytenum < 0 || bytenum > 3) {
    printf("pane: numero de byte invalido! \n");
    exit(1);
  }
  word = word >> (bytenum * 8);
  word = word & 0xFF;
  if (word & 0x80) {
    word = word | 0xFFFFFF00;
  }
  return word;
}

@livramos ➜ $ gcc -Wall ex3.c -o ex3
@livramos ➜ $ ./ex3
uso: ./ex3 <word (em hexadecimal)> <bytenum>
@livramos ➜ $ ./ex3 01abcd02 0
00000002  2
@livramos ➜ $ ./ex3 11a032b5 0
ffffffb5  -75
@livramos ➜ $ ./ex3 11a032b5 1
00000032  50
@livramos ➜ $ ./ex3 11a032b5 2
ffffffa0  -96
@livramos ➜ $ ./ex3 11a032b5 3
